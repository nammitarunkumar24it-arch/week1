/* ---------- Responsive ---------- */
@media(max-width:900px){
  .hero-grid,.about-grid,.contact-grid{grid-template-columns:1fr;gap:40px}
  .hero-text h1{font-size:2.4rem}
  .avatar-wrap{width:260px;height:260px}
