<style>
/* ---------- Design Tokens ---------- */
:root{
  --primary:#2563EB;
  --secondary:#0F172A;
  --accent:#38BDF8;
  --bg:#F8FAFC;
  --text:#1E293B;
  --muted:#64748B;
  --card:#ffffff;
  --shadow-sm:0 4px 12px rgba(15,23,42,.06);
  --shadow-md:0 12px 32px rgba(15,23,42,.10);
  --shadow-lg:0 24px 60px rgba(37,99,235,.18);
  --radius:16px;
  --gradient:linear-gradient(135deg,#2563EB 0%,#38BDF8 100%);
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  font-family:'Poppins',sans-serif;
  background:var(--bg);
  color:var(--text);
  line-height:1.6;
  overflow-x:hidden;
}
img{max-width:100%;display:block}
a{color:inherit;text-decoration:none}
.container{max-width:1180px;margin:0 auto;padding:0 24px}

/* ---------- Header ---------- */
header{
  position:sticky;top:0;z-index:100;
  background:rgba(255,255,255,.75);
  backdrop-filter:blur(14px);
  -webkit-backdrop-filter:blur(14px);
  border-bottom:1px solid rgba(15,23,42,.06);
 
}
.nav{display:flex;justify-content:space-between;align-items:center;padding:18px 0}
.logo{font-weight:800;font-size:1.35rem;color:var(--secondary)}
.logo span{color:var(--primary)}
.nav-links{display:flex;gap:28px;list-style:none}
.nav-links a{font-weight:500;color:var(--text);position:relative;transition:color .3s}
.nav-links a::after{content:'';position:absolute;left:0;bottom:-6px;width:0;height:2px;background:var(--gradient);transition:width .3s}
.nav-links a:hover{color:var(--primary)}
.nav-links a:hover::after{width:100%}
.menu-toggle{display:none;font-size:1.4rem;background:none;border:none;color:var(--secondary);cursor:pointer}

/* ---------- Buttons ---------- */
.btn{
  display:inline-flex;align-items:center;gap:8px;
  padding:12px 26px;border-radius:50px;font-weight:600;font-size:.95rem;
  cursor:pointer;border:none;transition:all .3s ease;
}
.btn-primary{background:var(--gradient);color:#fff;box-shadow:var(--shadow-md)}
.btn-primary:hover{transform:translateY(-3px);box-shadow:var(--shadow-lg)}
.btn-outline{background:transparent;color:var(--primary);border:2px solid var(--primary)}
.btn-outline:hover{background:var(--primary);color:#fff;transform:translateY(-3px)}

/* ---------- Sections ---------- */
section{padding:100px 0;scroll-margin-top:80px}
.section-title{text-align:center;margin-bottom:60px}
.section-title h2{font-size:2.4rem;font-weight:700;color:var(--secondary)}
.section-title h2 span{color:var(--primary)}
.section-title p{color:var(--muted);margin-top:10px}

/* ---------- Hero ---------- */
.hero{
  min-height:100vh;display:flex;align-items:center;position:relative;overflow:hidden;
  background:
    radial-gradient(circle at 20% 30%, rgba(56,189,248,.20), transparent 45%),
    radial-gradient(circle at 80% 70%, rgba(37,99,235,.20), transparent 45%),
    var(--bg);
}
.hero-grid{display:grid;grid-template-columns:1.2fr 1fr;gap:60px;align-items:center}
.hero-text .tag{display:inline-block;padding:6px 14px;background:rgba(37,99,235,.1);color:var(--primary);border-radius:50px;font-size:.85rem;font-weight:500;margin-bottom:18px;animation:fadeInUp .8s ease}
.hero-text h1{font-size:3.4rem;font-weight:800;line-height:1.15;color:var(--secondary);animation:fadeInUp 1s ease}
.hero-text h1 span{background:var(--gradient);-webkit-background-clip:text;background-clip:text;color:transparent}
.hero-text .role{font-size:1.15rem;color:var(--primary);font-weight:600;margin:14px 0;animation:fadeInUp 1.1s ease}
.hero-text p{color:var(--muted);font-size:1.02rem;max-width:540px;margin-bottom:30px;animation:fadeInUp 1.2s ease}
.hero-btns{display:flex;flex-wrap:wrap;gap:14px;animation:fadeInUp 1.3s ease}
.hero-image{display:flex;justify-content:center}
.avatar-wrap{
  width:340px;height:340px;border-radius:50%;
  background:var(--gradient);padding:6px;
  box-shadow:var(--shadow-lg);
  animation:float 6s ease-in-out infinite;
}
.avatar-wrap .avatar{
  width:100%;height:100%;border-radius:50%;
  background:#e2e8f0 url('https://ui-avatars.com/api/?name=Nammi+Tarun+Kumar&size=340&background=2563EB&color=fff&bold=true') center/cover no-repeat;
  border:6px solid var(--bg);
}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-18px)}}
@keyframes fadeInUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}

/* ---------- About ---------- */
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:50px;align-items:center}
.about-card{background:var(--card);padding:36px;border-radius:var(--radius);box-shadow:var(--shadow-sm)}
.about-card h3{color:var(--primary);margin-bottom:12px;font-size:1.25rem}
.about-card p{color:var(--muted)}
.about-stats{display:grid;grid-template-columns:repeat(2,1fr);gap:18px;margin-top:22px}
.stat{background:var(--card);padding:22px;border-radius:14px;box-shadow:var(--shadow-sm);text-align:center;transition:transform .3s}
.stat:hover{transform:translateY(-6px)}
.stat h4{font-size:1.7rem;color:var(--primary);font-weight:700}
.stat p{color:var(--muted);font-size:.9rem}

/* ---------- Education ---------- */
.edu-card{
  max-width:640px;margin:0 auto;
  background:var(--card);border-radius:var(--radius);
  padding:36px;box-shadow:var(--shadow-md);
  border-left:5px solid var(--primary);
  display:flex;gap:24px;align-items:flex-start;
  transition:transform .3s;
}
.edu-card:hover{transform:translateY(-6px)}
.edu-icon{
  width:60px;height:60px;flex-shrink:0;
  background:var(--gradient);color:#fff;
  border-radius:14px;display:grid;place-items:center;font-size:1.5rem;
}
.edu-card h3{color:var(--secondary);margin-bottom:6px}
.edu-card .inst{color:var(--primary);font-weight:600;margin-bottom:10px}
.edu-meta{display:flex;flex-wrap:wrap;gap:16px;color:var(--muted);font-size:.92rem}
.edu-meta span i{color:var(--accent);margin-right:6px}

/* ---------- Skills ---------- */
.skills-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:22px}
.skill{
  background:var(--card);padding:28px 20px;border-radius:var(--radius);
  text-align:center;box-shadow:var(--shadow-sm);
  transition:all .3s;
}
.skill:hover{transform:translateY(-8px);box-shadow:var(--shadow-lg)}
.skill i{font-size:2.4rem;background:var(--gradient);-webkit-background-clip:text;background-clip:text;color:transparent;margin-bottom:12px}
.skill h4{color:var(--secondary);margin-bottom:12px;font-weight:600}
.bar{width:100%;height:8px;background:#e2e8f0;border-radius:50px;overflow:hidden}
.bar span{display:block;height:100%;background:var(--gradient);border-radius:50px;transform-origin:left;animation:grow 1.4s ease forwards}
@keyframes grow{from{transform:scaleX(0)}to{transform:scaleX(1)}}

/* ---------- Services ---------- */
.services-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:24px}
.service{
  background:var(--card);padding:34px;border-radius:var(--radius);
  box-shadow:var(--shadow-sm);transition:all .3s;position:relative;overflow:hidden;
}
.service::before{content:'';position:absolute;inset:0;background:var(--gradient);opacity:0;transition:opacity .3s;z-index:0}
.service > *{position:relative;z-index:1;transition:color .3s}
.service:hover{transform:translateY(-8px);box-shadow:var(--shadow-lg)}
.service:hover::before{opacity:1}
.service:hover *{color:#fff !important}
.service .icon{
  width:60px;height:60px;border-radius:14px;background:rgba(37,99,235,.1);
  color:var(--primary);display:grid;place-items:center;font-size:1.5rem;margin-bottom:18px;
}
.service h3{margin-bottom:10px;color:var(--secondary)}
.service p{color:var(--muted);font-size:.95rem}

/* ---------- Projects ---------- */
.projects-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:26px}
.project{
  background:var(--card);border-radius:var(--radius);overflow:hidden;
  box-shadow:var(--shadow-sm);transition:all .3s;
}
.project:hover{transform:translateY(-8px);box-shadow:var(--shadow-lg)}
.project-img{
  height:200px;background:var(--gradient);
  display:grid;place-items:center;color:#fff;font-size:3rem;
}
.project-body{padding:26px}
.project-body h3{color:var(--secondary);margin-bottom:10px}
.project-body p{color:var(--muted);font-size:.95rem;margin-bottom:16px}
.tech{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:18px}
.tech span{background:rgba(37,99,235,.1);color:var(--primary);padding:4px 12px;border-radius:50px;font-size:.8rem;font-weight:500}
.project-links{display:flex;gap:12px}
.project-links a{color:var(--primary);font-weight:600;font-size:.9rem;display:inline-flex;gap:6px;align-items:center;transition:color .3s}
.project-links a:hover{color:var(--accent)}

/* ---------- Contact ---------- */
.contact-grid{display:grid;grid-template-columns:1fr 1.3fr;gap:40px}
.contact-info{display:flex;flex-direction:column;gap:18px}
.contact-item{
  background:var(--card);padding:22px;border-radius:var(--radius);
  box-shadow:var(--shadow-sm);display:flex;gap:16px;align-items:center;
  transition:transform .3s;
}
.contact-item:hover{transform:translateX(6px)}
.contact-item .icon{
  width:50px;height:50px;border-radius:12px;
  background:var(--gradient);color:#fff;
  display:grid;place-items:center;font-size:1.2rem;flex-shrink:0;
}
.contact-item h4{color:var(--secondary);font-size:.95rem;margin-bottom:2px}
.contact-item p{color:var(--muted);font-size:.9rem;word-break:break-word}
.contact-form{
  background:var(--card);padding:34px;border-radius:var(--radius);
  box-shadow:var(--shadow-md);
}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.form-group{margin-bottom:18px}
.form-group input,.form-group textarea{
  width:100%;padding:14px 16px;border:1.5px solid #e2e8f0;
  border-radius:12px;font-family:inherit;font-size:.95rem;
  background:var(--bg);color:var(--text);transition:border-color .2s, box-shadow .2s;
}
.form-group input:focus,.form-group textarea:focus{
  outline:none;border-color:var(--primary);box-shadow:0 0 0 4px rgba(37,99,235,.12);
}
.form-group textarea{resize:vertical;min-height:130px}

/* ---------- Footer ---------- */
footer{
  background:var(--secondary);color:#cbd5e1;padding:50px 0 24px;text-align:center;
